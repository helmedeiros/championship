{
  "browser": false,
  "node": true,
  "jquery": false,
  "globals": {
    "describe": false,
    "it": false,
    "before": false,
    "after": false,
    "beforeEach": false,
    "afterEach": false,
    "expect": false,
    "sinon": false,
    "window": true,
    "document": true,
    "navigator": true,
    "$": true,
    "jQuery": true
  },
  "curly": true,
  "eqeqeq": true,
  "expr": true,
  "latedef": "nofunc",
  "newcap": true,
  "noarg": true,
  "quotmark": "single",
  "undef": true,
  "unused": true,
  "trailing": true,
  "indent": 2,
  "maxlen": 100
}
