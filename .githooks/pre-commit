#!/usr/bin/env bash
#
# Pre-commit gate: hygiene + lint + tests.
# Skipped on the gh-pages branch — that branch only holds built artefacts.

set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

CURRENT_BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null || echo '')"
if [ "$CURRENT_BRANCH" = "gh-pages" ]; then
  echo "[pre-commit] branch gh-pages — gates desligados (somente artefatos)"
  exit 0
fi

if ! command -v node >/dev/null 2>&1; then
  if [ -d "$HOME/.nvm/versions/node" ]; then
    LATEST=$(ls -d "$HOME/.nvm/versions/node/"v* 2>/dev/null | sort -V | tail -1)
    [ -n "$LATEST" ] && export PATH="$LATEST/bin:$PATH"
  fi
fi

GRUNT="$ROOT/node_modules/.bin/grunt"
if [ ! -x "$GRUNT" ]; then
  echo "[pre-commit] node_modules/.bin/grunt não encontrado; rode 'npm install'." >&2
  exit 1
fi

exec "$GRUNT" hygiene lint test
