#!/usr/bin/env bash
#
# Pre-commit gate: hygiene + lint + tests.
# Aborts the commit on the first failing step.

set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# Make sure node/npm are reachable. Prefer whatever is already on PATH;
# otherwise pull the latest installed version from nvm.
if ! command -v node >/dev/null 2>&1; then
  if [ -d "$HOME/.nvm/versions/node" ]; then
    LATEST=$(ls -d "$HOME/.nvm/versions/node/"v* 2>/dev/null | sort -V | tail -1)
    [ -n "$LATEST" ] && export PATH="$LATEST/bin:$PATH"
  fi
fi

GRUNT="$ROOT/node_modules/.bin/grunt"
if [ ! -x "$GRUNT" ]; then
  echo "[pre-commit] node_modules/.bin/grunt not found; run 'npm install' first." >&2
  exit 1
fi

exec "$GRUNT" hygiene lint test
